{
  "name": "scrummate",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "start": "npm run start --workspace server",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:deploy": "npm run db:deploy --workspace server",
    "db:studio": "npm run db:studio --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
